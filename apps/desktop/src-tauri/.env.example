# Supabase — completeaza din dashboard: Project Settings -> API
# Local dev overrides; release builds use supabase.public.env via build.rs
# URL-ul proiectului (ex: https://abcdefgh.supabase.co)
SUPABASE_URL=
# "anon / public" API key (e ok sa fie in client, RLS protejeaza datele)
SUPABASE_ANON_KEY=

# URL-ul site-ului de management (browser login). Pentru dev: http://localhost:3000
AZALEA_WEB_URL=https://azalea-web.pages.dev
