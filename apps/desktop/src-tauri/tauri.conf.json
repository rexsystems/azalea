{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Azalea",
  "version": "0.1.0",
  "identifier": "com.azalea.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Azalea",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "en-US"
      }
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM0Rjg1ODJDOUYxOTYyQUEKUldTcVlobWZMRmo0TkpJSzZPeG96bVp6QVYzbk0vcXFWbWRIOW5hV2lMem93NmRWMVVkenlYZ20K",
      "endpoints": [
        "https://azalea-web.pages.dev/updates/latest.json",
        "https://github.com/rexsystems/azalea/releases/latest/download/latest.json"
      ]
    }
  }
}
